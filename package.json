{
  "name": "mcp-leclerc-drive",
  "version": "0.1.2",
  "mcpName": "io.github.skunkobi/leclerc-drive",
  "description": "MCP server for E.Leclerc Drive — search products, manage cart, and order groceries from Claude",
  "type": "module",
  "bin": {
    "mcp-leclerc-drive": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "inspect": "npx @modelcontextprotocol/inspector node dist/index.js",
    "smoke": "node scripts/smoke-test.mjs",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "leclerc",
    "leclerc-drive",
    "grocery",
    "courses"
  ],
  "author": "skunkobi",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/skunkobi/mcp-leclerc-drive.git"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "chrome-cookies-secure": "^3.0.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0"
  },
  "comment:overrides": "Force patched versions of sqlite3's (chrome-cookies-secure) build-time transitive deps to clear known CVEs. These are not used at runtime (sqlite3 ships a prebuilt binary).",
  "overrides": {
    "tar": "^7.5.16",
    "node-gyp": "^13.0.0",
    "cacache": "^21.0.1",
    "make-fetch-happen": "^15.0.6",
    "http-proxy-agent": "^9.1.0"
  }
}
